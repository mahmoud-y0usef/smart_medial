APP_NAME="الشفاء الذكي - Smart Medical"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=smart_medical
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DRIVER=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

FLARE_KEY=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Meta WhatsApp Business API
META_WHATSAPP_TOKEN=
META_VERIFY_TOKEN=
META_PHONE_ID=
META_BUSINESS_ACCOUNT_ID=

# AI Services (اختر واحد)
# Google Gemini (مجاني - الموصى به)
GOOGLE_AI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash-latest

# Groq (مجاني - سريع جداً)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile

# Ollama (محلي - مجاني)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=aya:8b

# OpenAI (مدفوع)
OPENAI_API_KEY=
OPENAI_ORGANIZATION=

# Anthropic (مدفوع)
ANTHROPIC_API_KEY=

# AI Configuration
AI_PRIMARY_PROVIDER=gemini
AI_FALLBACK_PROVIDER=groq

# Medical Platform
MEDICAL_QUEUE_UPDATE_INTERVAL=300
MEDICAL_DEFAULT_CONSULTATION_DURATION=15
MEDICAL_EMERGENCY_PRIORITY_THRESHOLD=8
